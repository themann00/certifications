# ============================================================
# Admin Authentication
# ============================================================
ADMIN_PASSWORD=your-secure-password-here
JWT_SECRET=your-random-jwt-secret-here

# ============================================================
# Vercel Blob (used in production; optional in development)
# Run `vercel env pull` to get this automatically, or use
# `vercel dev` which injects it. Without this token, the app
# will use the local ./data directory in development.
# ============================================================
BLOB_READ_WRITE_TOKEN=

# ============================================================
# Cloudinary (required for image uploads)
# Sign up free at cloudinary.com
# ============================================================
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
